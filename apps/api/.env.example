# Copy to apps/api/.env and fill in real values.

# Server
PORT=3001
WEB_URL=http://localhost:5173
API_URL=http://localhost:3001

# Server-side secret. Used to derive the key that encrypts OAuth tokens
# at rest in SQLite. Rotating this invalidates all stored tokens (users
# will need to re-link their GitHub/Google account).
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Database (SQLite for dev; Postgres URL later for production)
DATABASE_URL=file:./data/notekit.db

# --- GitHub OAuth ---
# Register at: https://github.com/settings/developers → "New OAuth App"
#   Application name:        NoteKit (dev)
#   Homepage URL:            http://localhost:5173
#   Authorization callback:  http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Google OAuth ---
# Register at: https://console.cloud.google.com/apis/credentials → "Create credentials" → "OAuth client ID" → "Web application"
#   Authorized JavaScript origins: http://localhost:5173
#   Authorized redirect URIs:      http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Telegram bot (M2) ---
# 1. DM @BotFather on Telegram, run /newbot, pick a name + username.
# 2. Save the token below. The username (without @) is what users see in t.me/<bot>?start=...
# 3. Production: set webhook with:
#    curl -F "url=https://api.example.com/integrations/telegram/webhook?secret=<TELEGRAM_WEBHOOK_SECRET>" \
#         https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook
#    Dev uses long-polling automatically.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# --- Web Push / VAPID (M3) ---
# Generate once with:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
# Subject is a mailto: or https: URL identifying you to push services.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- APNs (M5, iOS push) ---
# 1. Apple Developer → Keys → Create a key with "Apple Push Notifications service"
# 2. Download the .p8 file. Note the Key ID.
# 3. Team ID lives at Apple Developer → Membership.
# 4. Bundle ID is the same as APPLE_BUNDLE_ID below.
# Paste the .p8 contents with literal \n for line breaks:
#   APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\nMIGTAgEA...\n-----END PRIVATE KEY-----"
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.notekit.app
APNS_KEY_P8=
# Set to "true" when pushing to TestFlight/App Store builds; false for local dev.
APNS_PRODUCTION=false

# --- FCM (M5, Android push) ---
# 1. Firebase console → create project → add Android app with package name below.
# 2. Project Settings → Service Accounts → Generate new private key.
# 3. From that JSON: project_id, client_email, private_key.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# --- Apple IAP / App Store Server API (M6) ---
# 1. App Store Connect → Users and Access → Integrations → App Store Connect API
#    → Generate a key with "App Store Server API" access. Download the .p8.
# 2. Issuer ID is shown above the keys list.
# 3. Configure App Store Server Notifications V2 URL in App Store Connect:
#    https://api.example.com/iap/apple/webhook
APPLE_BUNDLE_ID=com.notekit.app
APPLE_ISSUER_ID=
APPLE_API_KEY_ID=
APPLE_API_KEY_P8=
APPLE_SHARED_SECRET=

# --- Google Play IAP (M6) ---
# 1. Google Play Console → Setup → API access → link a GCP project.
# 2. Create a service account with "Financial data" + "Manage orders" perms.
# 3. Download its JSON key → fill below.
# 4. Cloud Pub/Sub → create a topic for RTDN. In Play Console → Monetization
#    setup → wire that topic.
# 5. Create a Pub/Sub push subscription pointing at:
#    https://api.example.com/iap/google/webhook?secret=<GOOGLE_PLAY_PUBSUB_SECRET>
GOOGLE_PLAY_PACKAGE_NAME=com.notekit.app
GOOGLE_PLAY_CLIENT_EMAIL=
GOOGLE_PLAY_PRIVATE_KEY=
GOOGLE_PLAY_PUBSUB_SECRET=
