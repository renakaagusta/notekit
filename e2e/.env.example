# A NoteKit personal access token used by the Maestro suite to sign in
# without driving OAuth-in-WebView (which is brittle on Capacitor).
#
# Mint one against the API the tests will hit:
#   - Local dev:  hit http://localhost:3001/auth/dev-login (sets cookie),
#                 then POST /auth/tokens with name="e2e-maestro", scope="cli".
#   - Prod:       sign in to the web app, open Settings → Personal access
#                 tokens, create one named "e2e-maestro".
#
# Copy to e2e/.env (which is gitignored) and replace.
E2E_PAT=nkp_replace-me

# Where the mobile build points its API client. Two patterns:
#   - http://localhost:3001              (iOS sim only — sim shares host net)
#   - http://10.0.2.2:3001                (Android emu — magic host alias)
#   - https://api.notekit.online         (prod, requires CORS_EXTRA_ORIGINS
#                                          set on the server)
E2E_API_URL=http://localhost:3001
