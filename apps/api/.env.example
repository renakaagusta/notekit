# Copy to apps/api/.env and fill in real values.

# Server
PORT=3001
WEB_URL=http://localhost:5173
API_URL=http://localhost:3001

# Server-side secret. Used to derive the key that encrypts OAuth tokens
# at rest in SQLite. Rotating this invalidates all stored tokens (users
# will need to re-link their GitHub/Google account).
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Database (SQLite for dev; Postgres URL later for production)
DATABASE_URL=file:./data/notekit.db

# --- GitHub OAuth ---
# Register at: https://github.com/settings/developers → "New OAuth App"
#   Application name:        NoteKit (dev)
#   Homepage URL:            http://localhost:5173
#   Authorization callback:  http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Google OAuth ---
# Register at: https://console.cloud.google.com/apis/credentials → "Create credentials" → "OAuth client ID" → "Web application"
#   Authorized JavaScript origins: http://localhost:5173
#   Authorized redirect URIs:      http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
