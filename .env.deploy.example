# ── Domains ────────────────────────────────────────────────────────────────────
ROOT_DOMAIN=stackbase.id
WEB_DOMAIN=notekit.stackbase.id
API_DOMAIN=notekit-api.stackbase.id

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
# Register at: https://github.com/settings/developers → New OAuth App
#   Homepage URL:           https://notekit.stackbase.id
#   Authorization callback: https://api.notekit.stackbase.id/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram bot (optional) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# ── Web Push / VAPID (optional) ────────────────────────────────────────────────
# Generate: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Apple IAP (optional) ───────────────────────────────────────────────────────
APPLE_BUNDLE_ID=com.notekit.app
APPLE_ISSUER_ID=
APPLE_API_KEY_ID=
APPLE_API_KEY_P8=
APPLE_SHARED_SECRET=

# ── Google Play IAP (optional) ─────────────────────────────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=com.notekit.app
GOOGLE_PLAY_CLIENT_EMAIL=
GOOGLE_PLAY_PRIVATE_KEY=
GOOGLE_PLAY_PUBSUB_SECRET=
