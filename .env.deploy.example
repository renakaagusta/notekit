# ── Domains ────────────────────────────────────────────────────────────────────
ROOT_DOMAIN=notekit.online
WEB_DOMAIN=notekit.online
API_DOMAIN=api.notekit.online
GIT_DOMAIN=git.notekit.online

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
# Register at: https://github.com/settings/developers → New OAuth App
#   Homepage URL:           https://notekit.online
#   Authorization callback: https://api.notekit.online/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram bot (optional) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# ── Web Push / VAPID (optional) ────────────────────────────────────────────────
# Generate: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Apple IAP (optional) ───────────────────────────────────────────────────────
APPLE_BUNDLE_ID=com.notekit.app
APPLE_ISSUER_ID=
APPLE_API_KEY_ID=
APPLE_API_KEY_P8=
APPLE_SHARED_SECRET=

# ── Google Play IAP (optional) ─────────────────────────────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=com.notekit.app
GOOGLE_PLAY_CLIENT_EMAIL=
GOOGLE_PLAY_PRIVATE_KEY=
GOOGLE_PLAY_PUBSUB_SECRET=

# ── Self-hosted Git (Forgejo) ──────────────────────────────────────────────────
# Generate keys with: openssl rand -hex 32
FORGEJO_SECRET_KEY=
FORGEJO_INTERNAL_TOKEN=
# One-time setup (after first deploy):
#   docker exec notekit-git forgejo admin user create \
#     --admin --username notekit-admin \
#     --password <strong-password> \
#     --email admin@notekit.online \
#     --must-change-password=false
#   docker exec notekit-git forgejo admin user generate-access-token \
#     --username notekit-admin --token-name notekit-api --raw
FORGEJO_ADMIN_TOKEN=
