# Production-mode Vite env (also picked up for `pnpm --filter @notekit/web build`).
# Copy to .env.production and replace with the deployment you target.
#
# Examples:
#   - prod:  https://notekit-api.stackbase.id
#   - dev:   http://localhost:3001          (also the default if unset)
VITE_API_URL=http://localhost:3001
