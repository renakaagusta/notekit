{
  "name": "@notekit/mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Model Context Protocol server exposing NoteKit notes, tickets, and vault to LLM clients.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "notekit-mcp": "./bin/notekit-mcp.mjs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notekit/api-client": "workspace:*",
    "@notekit/core": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.4.5"
  }
}
